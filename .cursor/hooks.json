{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "name": "repository-health",
        "command": "node -e \"const f=require('node:fs'),p=require('node:path'),u=require('node:url');let d=process.cwd(),s;for(;;){s=p.join(d,'.mstack','runtime','hooks','repository-health.mjs');if(f.existsSync(s))break;const n=p.dirname(d);if(n===d)process.exit(0);d=n};import(u.pathToFileURL(s).href)\"",
        "timeout": 5
      }
    ],
    "preToolUse": [
      {
        "name": "change-discipline",
        "command": "node -e \"const f=require('node:fs'),p=require('node:path'),u=require('node:url');let d=process.cwd(),s;for(;;){s=p.join(d,'.mstack','runtime','hooks','change-discipline.mjs');if(f.existsSync(s))break;const n=p.dirname(d);if(n===d)process.exit(0);d=n};import(u.pathToFileURL(s).href)\"",
        "timeout": 2
      }
    ],
    "afterAgentResponse": [
      {
        "name": "feature-completeness",
        "command": "node -e \"const f=require('node:fs'),p=require('node:path'),u=require('node:url');let d=process.cwd(),s;for(;;){s=p.join(d,'.mstack','runtime','hooks','feature-completeness.mjs');if(f.existsSync(s))break;const n=p.dirname(d);if(n===d)process.exit(0);d=n};import(u.pathToFileURL(s).href)\"",
        "timeout": 5
      }
    ]
  }
}
