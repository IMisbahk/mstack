{
  "name": "@imisbahk/mstack",
  "version": "0.3.0",
  "description": "Install the Build Like This AI engineering workflow in any repository",
  "type": "module",
  "bin": {
    "mstack": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "templates",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "sync-assets": "node scripts/sync-assets.mjs",
    "prebuild": "npm run sync-assets",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs:generate": "node scripts/generate-command-reference.mjs",
    "prepublishOnly": "npm run typecheck && npm test && npm run build",
    "release:check": "npm run prepublishOnly && npm pack --dry-run"
  },
  "keywords": [
    "ai",
    "ai-agents",
    "cli",
    "coding-agents",
    "developer-tools",
    "developer-experience",
    "project-scaffold",
    "buildlikethis",
    "claude-code",
    "codex",
    "cursor"
  ],
  "author": "Misbah Khursheed",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IMisbahk/mstack.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/IMisbahk/mstack/issues"
  },
  "homepage": "https://github.com/IMisbahk/mstack#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "commander": "^14.0.1",
    "picocolors": "^1.1.1",
    "semver": "^7.7.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.13",
    "@types/semver": "^7.7.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
